<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardBackgroundColor="@color/safe_browsing_warning_background"
    app:cardElevation="4dp"
    app:cardCornerRadius="8dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Warning Icon -->
        <ImageView
            android:id="@+id/warningIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_safe_browsing_warning"
            android:contentDescription="@string/safe_browsing_warning_icon_description"
            android:tint="@color/safe_browsing_warning_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Warning Title -->
        <TextView
            android:id="@+id/warningTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="@string/safe_browsing_warning_title"
            android:textColor="@color/safe_browsing_warning_text"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/closeButton"
            app:layout_constraintStart_toEndOf="@+id/warningIcon"
            app:layout_constraintTop_toTopOf="@+id/warningIcon" />

        <!-- Close Button -->
        <ImageButton
            android:id="@+id/closeButton"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_close_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/safe_browsing_close_description"
            android:tint="@color/safe_browsing_warning_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Threat Description -->
        <TextView
            android:id="@+id/threatDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/safe_browsing_warning_text"
            android:textSize="14sp"
            tools:text="This site has been flagged as Phishing"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/warningIcon"
            app:layout_constraintTop_toBottomOf="@+id/warningTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
