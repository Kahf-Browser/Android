<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/newTabLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipChildren="false"
    tools:context="com.duckduckgo.app.browser.BrowserActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/browserBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="?attr/actionBarSize"
        android:visibility="gone"
        tools:visibility="visible"
        android:foreground="@android:color/transparent">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/newTabWallpaper"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:src="@drawable/background_mosque"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/newTabContainerLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="@dimen/keyline_2"
            android:layout_marginBottom="@dimen/keyline_4">

            <!-- Social Media + Statistics Bar -->
            <include
                android:id="@+id/socialMediaAndStatsBar"
                layout="@layout/include_social_media_bar" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/historyRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:layout_marginVertical="5dp"
                android:layout_marginHorizontal="@dimen/kahf_new_tab_content_margin"
                android:paddingHorizontal="@dimen/keyline_1"
                android:paddingTop="@dimen/keyline_2"
                android:background="@drawable/app_statistics_bg"
                tools:itemCount="7"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_behavior="@string/appbar_scrolling_view_behavior"
                tools:listitem="@layout/item_history_entry" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottomContentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/bottomNavHeight"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.kahfads.sdk.MediumBannerAdView
                android:id="@+id/kahfBannerAd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/kahf_new_tab_content_margin"/>

            <LinearLayout
                android:id="@+id/textContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/wallpaper_gradient_overlay"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="15dp"
                android:paddingVertical="3dp"
                android:visibility="visible"
                app:layout_constraintBottom_toTopOf="@id/kahfBannerAd"
                app:layout_constraintStart_toStartOf="parent"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/lato"
                    android:gravity="center"
                    android:maxLines="2"
                    android:textAlignment="center"
                    android:textColor="@android:color/darker_gray"
                    android:textSize="17sp"
                    tools:text="Title" />

                <TextView
                    android:id="@+id/subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/lato"
                    android:gravity="center"
                    android:maxLines="2"
                    android:textAlignment="center"
                    android:textColor="@android:color/darker_gray"
                    android:textSize="13sp"
                    tools:text="Subtitle" />

                <TextView
                    android:id="@+id/photoCredit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:ellipsize="end"
                    android:fontFamily="@font/lato"
                    android:gravity="center"
                    android:maxLines="1"
                    android:paddingVertical="3dp"
                    android:textAlignment="center"
                    android:textColor="@android:color/darker_gray"
                    android:textSize="11sp"
                    tools:text="Photo Credit" />
            </LinearLayout>
        </LinearLayout>

        <include
            android:id="@+id/includeDaxDialogIntroBubbleCta"
            layout="@layout/include_dax_dialog_intro_bubble_cta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/keyline_2"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="600dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>

