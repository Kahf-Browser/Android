<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/newTabLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipChildren="false"
    tools:context="com.duckduckgo.app.browser.BrowserActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/browserBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="?attr/actionBarSize"
        android:foreground="@android:color/transparent">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/newTabWallpaper"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:src="@drawable/background_mosque"
            android:foreground="@drawable/wallpaper_gradient_overlay"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/newTabContainerLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="@dimen/keyline_2"
            android:layout_marginBottom="@dimen/keyline_4">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/appStat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/app_statistics_bg"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:weightSum="3"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="0dp">

                        <TextView
                            android:id="@+id/siteBlockCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="12k"
                            tools:ignore="DeprecatedWidgetInXml" />

                        <TextView
                            android:id="@+id/siteBlockLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:text="@string/kahf_harmful_sites"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            tools:ignore="DeprecatedWidgetInXml" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="0dp">

                        <TextView
                            android:id="@+id/imageBlockedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="514"
                            tools:ignore="DeprecatedWidgetInXml" />

                        <TextView
                            android:id="@+id/imageBlockedLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:text="@string/kahf_indecent_pictures"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            tools:ignore="DeprecatedWidgetInXml" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="0dp">

                        <TextView
                            android:id="@+id/trackerBlockedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="860"
                            tools:ignore="DeprecatedWidgetInXml" />

                        <TextView
                            android:id="@+id/trackerBlockedLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:text="@string/kahf_ads_trackers"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            tools:ignore="DeprecatedWidgetInXml" />
                    </LinearLayout>


                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/historyRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:layout_marginVertical="5dp"
                android:paddingHorizontal="@dimen/keyline_2"
                tools:itemCount="7"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_behavior="@string/appbar_scrolling_view_behavior"
                tools:listitem="@layout/item_history_entry" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/textContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="60dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:visibility="visible">

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/lato"
                android:gravity="center"
                android:maxLines="2"
                android:textAlignment="center"
                android:textColor="@android:color/darker_gray"
                android:textSize="17sp"
                tools:text="Title" />

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/lato"
                android:gravity="center"
                android:maxLines="2"
                android:textAlignment="center"
                android:textColor="@android:color/darker_gray"
                android:textSize="13sp"
                tools:text="Subtitle" />

            <TextView
                android:id="@+id/photoCredit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:ellipsize="end"
                android:fontFamily="@font/lato"
                android:gravity="center"
                android:maxLines="1"
                android:paddingVertical="3dp"
                android:textAlignment="center"
                android:textColor="@android:color/darker_gray"
                android:textSize="11sp"
                tools:text="Photo Credit" />
        </LinearLayout>

        <include
            android:id="@+id/includeDaxDialogIntroBubbleCta"
            layout="@layout/include_dax_dialog_intro_bubble_cta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/keyline_2"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="600dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
