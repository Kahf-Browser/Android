<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/quickAccessFaviconCard"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:paddingHorizontal="15dp"
        app:cardCornerRadius="80dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/historyItemLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/historyItemImage"
            android:layout_width="32dp"
            android:layout_height="32dp"
            tools:src="@tools:sample/avatars"
            android:layout_gravity="center"
            app:shapeAppearanceOverlay="@style/circleImageView"
            android:scaleType="fitXY"
            android:importantForAccessibility="no"/>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/historyItemLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        app:typography="caption"
        app:textType="secondary"
        tools:text="It's a long label"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingHorizontal="3dp"
        android:paddingTop="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/quickAccessFaviconCard" />

</androidx.constraintlayout.widget.ConstraintLayout>