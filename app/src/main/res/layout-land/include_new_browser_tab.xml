<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/newTabLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.duckduckgo.app.browser.BrowserActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/browserBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:foreground="@android:color/transparent"
        android:paddingTop="?attr/actionBarSize">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/newTabWallpaper"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:foreground="@drawable/wallpaper_gradient_overlay"
            android:scaleType="centerCrop"
            android:src="@drawable/background_mosque"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/newTabContainerLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guidelineTop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.02" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guidelineMid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.5" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrier"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:barrierMargin="3dp"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="statContainer,historyRecyclerView" />

            <LinearLayout
                android:id="@+id/statContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/app_statistics_bg"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:padding="10dp"
                android:layout_marginHorizontal="3dp"
                android:layout_marginTop="@dimen/keyline_1"
                android:weightSum="3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/guidelineMid"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/barrier">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="0dp">

                    <TextView
                        android:id="@+id/siteBlockCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:textColor="@android:color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:ignore="DeprecatedWidgetInXml"
                        tools:text="12k" />

                    <TextView
                        android:id="@+id/siteBlockLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="@string/kahf_harmful_sites"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        tools:ignore="DeprecatedWidgetInXml" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="0dp">

                    <TextView
                        android:id="@+id/imageBlockedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:textColor="@android:color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:ignore="DeprecatedWidgetInXml"
                        tools:text="514" />

                    <TextView
                        android:id="@+id/imageBlockedLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="@string/kahf_indecent_pictures"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        tools:ignore="DeprecatedWidgetInXml" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="0dp">

                    <TextView
                        android:id="@+id/trackerBlockedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:textColor="@android:color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:ignore="DeprecatedWidgetInXml"
                        tools:text="860" />

                    <TextView
                        android:id="@+id/trackerBlockedLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="@string/kahf_ads_trackers"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        tools:ignore="DeprecatedWidgetInXml" />
                </LinearLayout>


            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/historyRecyclerView"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/app_statistics_bg"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/keyline_1"
                android:paddingTop="@dimen/keyline_2"
                android:visibility="visible"
                tools:visibility="visible"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/barrier"
                app:layout_constraintStart_toEndOf="@id/guidelineMid"
                tools:itemCount="7"
                tools:listitem="@layout/item_history_entry" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/bottomContentContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/bottomNavHeight"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/barrier"
                app:layout_constraintVertical_bias="1.0">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guidelineMidChild"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.5" />

                <co.kahf.adsdk.adviews.KahfBannerAdView
                    android:id="@+id/kahfBannerAd"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/keyline_1"
                    android:layout_marginTop="@dimen/keyline_1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/guidelineMidChild"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <LinearLayout
                    android:id="@+id/textContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="5dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="visible"
                    android:foreground="@drawable/wallpaper_gradient_overlay"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/guidelineMidChild"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/lato"
                        android:gravity="center"
                        android:maxLines="2"
                        android:textAlignment="center"
                        android:textColor="#777"
                        android:textSize="17sp"
                        tools:text="Title" />

                    <TextView
                        android:id="@+id/subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/lato"
                        android:gravity="center"
                        android:maxLines="2"
                        android:textAlignment="center"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="13sp"
                        tools:text="Subtitle" />

                    <TextView
                        android:id="@+id/photoCredit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:ellipsize="end"
                        android:fontFamily="@font/lato"
                        android:gravity="center"
                        android:maxLines="1"
                        android:paddingVertical="3dp"
                        android:textAlignment="center"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="11sp"
                        tools:text="Photo Credit" />
                </LinearLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>



        </androidx.constraintlayout.widget.ConstraintLayout>

        <include
            android:id="@+id/includeDaxDialogIntroBubbleCta"
            layout="@layout/include_dax_dialog_intro_bubble_cta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/keyline_2"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="600dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
