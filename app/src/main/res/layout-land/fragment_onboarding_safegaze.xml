<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/onboarding_bg_sg">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineMiddle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineHorizontalMiddle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.35" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineBottom"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.9" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_bold"
        android:gravity="center"
        android:text="@string/kahf_onboarding_sg_title"
        android:textColor="@color/kahf_onboarding_title"
        android:textSize="35sp"
        app:layout_constraintTop_toTopOf="@id/guidelineHorizontalMiddle"
        app:layout_constraintBottom_toBottomOf="@id/guidelineHorizontalMiddle"
        app:layout_constraintEnd_toEndOf="@id/guidelineMiddle"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="DeprecatedWidgetInXml,InvalidColorAttribute" />

    <ImageView
        android:id="@+id/ivMobile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/_0"
        android:src="@drawable/onboarding_sg"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/guidelineMiddle"
        app:layout_constraintTop_toTopOf="@id/titleText"
        app:layout_constraintBottom_toBottomOf="@id/titleText"/>

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:gravity="center"
        android:text="@string/kahf_onboarding_sg_subtitle"
        android:textColor="?attr/daxColorBlack"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/guidelineMiddle"
        app:layout_constraintTop_toBottomOf="@id/compatibilityLayout"
        app:layout_constraintBottom_toTopOf="@id/compatibilityLayout"
        tools:ignore="DeprecatedWidgetInXml" />

    <LinearLayout
        android:id="@+id/compatibilityLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="5dp"
        app:layout_constraintBottom_toTopOf="@id/btnEnableSafeGaze"
        app:layout_constraintEnd_toEndOf="@id/guidelineMiddle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintVertical_bias="0.5">

        <ProgressBar
            android:id="@+id/progressLoader"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginEnd="8dp"
            android:indeterminate="true"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tvCompatibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            android:text="@string/kahf_onboarding_checking_compatibility"
            android:textColor="?attr/daxColorBlack"
            android:textSize="13.5sp"
            tools:ignore="DeprecatedWidgetInXml" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/btnEnableSafeGaze"
        android:layout_width="@dimen/kahf_onboard_button_width"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/kahf_onboarding_button_2"
        app:cardCornerRadius="10dp"
        app:layout_constraintBottom_toTopOf="@id/guidelineBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="InvalidColorAttribute">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/inter"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="@string/kahf_onboarding_sg_enable"
            android:textColor="?attr/daxColorWhite"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:ignore="DeprecatedWidgetInXml" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/btnSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="5dp"
        android:text="@string/kahf_onboarding_skip"
        android:textColor="@color/kahf_onboarding_skip"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnEnableSafeGaze"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnEnableSafeGaze"
        app:layout_constraintTop_toTopOf="@id/btnEnableSafeGaze"
        tools:ignore="DeprecatedWidgetInXml,InvalidColorAttribute" />

</androidx.constraintlayout.widget.ConstraintLayout>
